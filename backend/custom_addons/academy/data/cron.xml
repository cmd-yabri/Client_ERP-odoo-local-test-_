<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_check_courses" model="ir.cron">
            <field name="name">Academy: Daily Course Check</field>
            <field name="model_id" search="[('model', '=', 'academy.course')]" model="ir.model"/>
            <field name="state">code</field>
            <field name="code">model.check_active_courses()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>