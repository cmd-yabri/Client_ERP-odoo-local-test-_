<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_course_details_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <h2 t-out="o.name"/>
                        <p>Status: <span t-out="o.state"/></p>
                        
                        <table class="table table-sm" t-if="o.student_ids">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.student_ids" t-as="student">
                                    <tr>
                                        <td><span t-out="student.name"/></td>
                                        <td><span t-out="student.email"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>